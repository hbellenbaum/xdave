! DO NOT MODIFY THIS FILE
$SETUP
	mode_of_operation = "{mode_of_operation}"
	number_of_ions = 3
	perform_error_checks = .TRUE.
	run_code_silently = .TRUE.
$END
$FILE
	output_file_name = "{output_file_name}"
	status_file_name = "{status_file_name}"
$END
$PLASMA
	use_mean_charge_states = .FALSE.
	atomic_number = {AN1:0.2f}, {AN2:0.2f}, {AN3:0.2f}
	ionization_state = {Z1:0.2f}, {Z2:0.2f}, {Z3:0.2f}
	density_fraction = {x1:0.2f}, {x2:0.2f}, {x3:0.2f}
	mass_density = {rho:0.2f}
	temperature = {T:0.2f}
	bulk_flow_along_k = 0.
$END
$PROBE
	probe_energy = {probe_energy:0.0f}
	use_source_func_data = {use_source_func_data}
	source_func_shape = "{source_func_shape}"
	use_source_func_data = {use_source_func_data}
	source_func_fwhm_ev = {source_func_fwhm_ev:0.2f}
    source_func_file_name = "{source_func_file_name}"
$END
$DETECTOR
	number_of_points = {n_points:d}
	min_scat_energy = {E_min:0.0f}
	max_scat_energy = {E_max:0.0f}
	scattering_angle = {angle:0.0f}
	max_scat_angle = {angle:0.0f}
	min_scat_angle = {angle:0.0f}
$END
$MODELS
	ee_pol_func_model = "{ee_pol_func_model}"
	ee_lfc_model = "{ee_lfc_model}"
	ii_potential_model = "{ii_potential_model}"
	screen_cloud_model = "{screen_cloud_model}"
	ei_potential_model = "{ei_potential_model}"
	bf_dsf_model = "{bf_dsf_model}"
	sec_core_power = {sec_core_power:0.0f}
	ion_core_radius = 40
	use_ideal_wr = .FALSE.
	ipd_model = "{ipd_model}"
	calculate_rk_factor = .FALSE.
	user_defined_Gee = ({user_defined_Gee:0.5f}, 0.0)
	! ee_pol_func_model = "BORN_MERMIN"
	! ee_lfc_model = "STATIC_UTSUMI_ICHIMARU"
	! ii_potential_model = "DEBYE_HUCKEL"
	! screen_cloud_model = "FINITE_WAVELENGTH"
	! ei_potential_model = "EFFECTIVE_COULOMB"
	! bf_dsf_model = "IMPULSE_SCHUMACHER"
	! sec_core_power = 6
	! ion_core_radius = 40
	! use_ideal_wr = .FALSE.
	! ideal_peak_ratio = 2.8
	! ipd_model = "STEWART_PYATT"
	! calibration_energy = 5780
	! calculate_rk_factor = .FALSE.
$END